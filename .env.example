# ============================================================
# RaftaarRide — Environment Variables Reference
# Copy this file, fill in real values, and set on your host
# (Railway, Render, Fly.io, VPS, etc.)
# ============================================================

# ── API Server (artifacts/api-server) ───────────────────────

# PostgreSQL connection string (required)
# Free options: Neon (neon.tech), Supabase, Railway Postgres
DATABASE_URL=postgresql://user:password@host:5432/raftaarride

# Secret key for JWT signing (generate: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# Razorpay payment gateway (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# RazorpayX for driver payouts (optional — leave blank if not using)
RAZORPAYX_ACCOUNT_NUMBER=

# SMS OTP via 2Factor (https://2factor.in)
TWOFACTOR_API_KEY=your_2factor_api_key

# Fast2SMS (alternative SMS provider — optional)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Firebase Admin (for push notifications — optional)
# Paste the full JSON of your Firebase service account key as a single line
GOOGLE_SERVICE_ACCOUNT_KEY=

# OpenAI (for voice AI features — optional)
OPENAI_API_KEY=

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Node environment
NODE_ENV=production

# Port the API server listens on
PORT=8080

# ── Admin Panel (artifacts/admin) ───────────────────────────

# Full URL of your deployed API server (no trailing slash)
# Example: https://your-api.railway.app
VITE_API_URL=https://your-api.railway.app

# ── Mobile App (artifacts/mobile) ───────────────────────────

# Domain of your deployed API server (without https:// or /api)
# Example: your-api.railway.app
EXPO_PUBLIC_DOMAIN=your-api.railway.app

# Google Maps API key (https://console.cloud.google.com)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# Firebase API key for mobile auth (https://console.firebase.google.com)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
