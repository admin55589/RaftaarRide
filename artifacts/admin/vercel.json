{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/admin run build",
  "outputDirectory": "dist/public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/api/:path*", "destination": "https://68e41a5f-c1bd-4337-9c0e-5f9c6dd535e1-00-3rxx9zjx78ze2.janeway.replit.dev/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
